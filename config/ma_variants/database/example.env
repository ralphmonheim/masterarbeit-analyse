# Beispiel fuer lokale Umgebungsvariablen. Keine echten Zugangsdaten eintragen.
#
# Direkte URL, falls alle Verbindungsdaten bereits zentral verwaltet werden:
# MA_VARIANTS_DATABASE_URL=postgresql+psycopg://<user>:<password>@localhost:5432/<database>
#
# Alternativ wird die URL aus Einzelwerten zusammengesetzt:
MA_VARIANTS_DB_DIALECT=postgresql+psycopg
MA_VARIANTS_DB_HOST=localhost
MA_VARIANTS_DB_PORT=5432
# MA_VARIANTS_DB_NAME=<database>
# MA_VARIANTS_DB_USER=<user>
# MA_VARIANTS_DB_PASSWORD=<password>
MA_VARIANTS_DB_ECHO=false
MA_VARIANTS_DB_POOL_PRE_PING=true
