# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.pytest_basetemp/
.pytest_temp/
*.egg-info/
.ruff_cache/
.cache/

# Lokale Umgebung
.venv/
.env

# Lokale Arbeitsdaten und erzeugte Ausgaben
data/input/*
!data/input/.gitkeep
data/database/*
!data/database/.gitkeep
data/output/*
!data/output/.gitkeep
data/test_output/*
!data/test_output/.gitkeep
data/imports/*
!data/imports/.gitkeep
data/reports/*
!data/reports/.gitkeep
data/exports/*
!data/exports/.gitkeep
!data/exports/example_*.json
!data/exports/example_*.csv
data/ida_exports/*
!data/ida_exports/.gitkeep

# Logs und temporaere Dateien
logs/*.log
!logs/.gitkeep
*.log
*.tmp
*.bak
~$*
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
